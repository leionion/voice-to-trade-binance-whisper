# .env.example — API keys (optional, overrides config.yaml)
# Copy to .env and fill in. Never commit .env to git.

# Whisper API mode (whisper.mode: "api") — skip local model, use OpenAI cloud
OPENAI_API_KEY=

# Live Binance trading (--mode live) — create at binance.com API Management
BINANCE_API_KEY=
BINANCE_API_SECRET=
